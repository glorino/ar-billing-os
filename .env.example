# Environment Variables
# Copy this to .env.local and fill in your values

# Database (Neon PostgreSQL)
DATABASE_URL="postgresql://user:password@host/dbname?sslmode=require"
DATABASE_URL_UNPOOLED="postgresql://user:password@host/dbname?sslmode=require"

# Clerk Authentication
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY="pk_live_your_clerk_key"
CLERK_SECRET_KEY="sk_live_your_clerk_key"
CLERK_WEBHOOK_SECRET="whsec_your_webhook_secret"

# Stripe (Global markets)
STRIPE_SECRET_KEY="sk_live_your_stripe_key"
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_live_your_stripe_key"
STRIPE_WEBHOOK_SECRET="whsec_your_stripe_webhook"

# Paystack (African markets: NG, GH, KE, ZA, TZ, UG, etc.)
PAYSTACK_SECRET_KEY="sk_live_your_paystack_key"
NEXT_PUBLIC_PAYSTACK_PUBLIC_KEY="pk_live_your_paystack_key"
PAYSTACK_WEBHOOK_SECRET="whsec_your_paystack_webhook"

# OpenAI
OPENAI_API_KEY="sk-your_openai_key"

# Trigger.dev
TRIGGER_SECRET_KEY="tr_prod_your_trigger_key"
NEXT_PUBLIC_TRIGGER_API_KEY="tr_prod_your_trigger_key"

# Redis (Upstash)
REDIS_URL="rediss://:password@host:6379"
UPSTASH_REDIS_REST_URL="https://your-instance.upstash.io"
UPSTASH_REDIS_REST_TOKEN="your_upstash_token"

# App
NEXT_PUBLIC_APP_URL="https://your-domain.com"
NEXT_PUBLIC_APP_NAME="AR Billing OS"

# Encryption
ENCRYPTION_KEY="generate_a_32_char_random_key_here"
